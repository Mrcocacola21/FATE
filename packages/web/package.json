{
  "name": "web",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "generate:favicons": "node scripts/generate-favicons.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test:gameplay": "tsx --test src/store.selection.test.ts",
    "test:action-ui": "tsx --test src/game/components/RightPanel/actionSummaries.test.tsx",
    "test:i18n": "tsx --test src/i18n/i18n.test.ts",
    "test:previews": "tsx --test src/game/targeting/*.test.ts",
    "test:ability-details": "tsx --test src/game/abilityDisplayDetails.test.tsx",
    "test:layout": "tsx --test src/game/hooks/useBoardFit.test.ts",
    "test:assets": "tsx --test src/assets/unitVisuals.test.ts",
    "test:effects": "tsx --test src/game/effects/*.test.ts",
    "test:test-room": "tsx --test src/testRoom/*.test.ts",
    "check:i18n": "npm run typecheck && npm run test:i18n",
    "preview": "vite preview"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-markdown": "^9.1.0",
    "rules": "file:../rules",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@types/node": "24.10.1",
    "@types/react": "^18.2.66",
    "@types/react-dom": "^18.2.22",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.18",
    "png-to-ico": "^3.0.1",
    "postcss": "^8.4.36",
    "sharp": "^0.35.2",
    "tailwindcss": "^3.4.1",
    "tsx": "4.21.0",
    "typescript": "^5.9.3",
    "vite": "^5.2.0"
  }
}
